{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "out",
    "rootDir": "src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "noImplicitAny": false
  },
  "include": ["src/server/**/*", "src/main/**/*"],
  "exclude": [
    "src/main/index.ts",
    "src/main/ipc/**",
    "src/renderer/**",
    "src/preload/**"
  ]
}
