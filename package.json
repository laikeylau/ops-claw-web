{
  "name": "ops-claw",
  "version": "1.0.0",
  "description": "Ops Claw - AI-powered SSH server management with chat-style interface",
  "author": {
    "name": "Ops Claw Contributors",
    "email": "contact@opsclaw.dev"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/laikeylau/ops-claw.git"
  },
  "homepage": "https://github.com/laikeylau/ops-claw#readme",
  "bugs": {
    "url": "https://github.com/laikeylau/ops-claw/issues"
  },
  "keywords": [
    "ssh",
    "server-management",
    "electron",
    "ai",
    "terminal",
    "chat",
    "devops",
    "remote-access"
  ],
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "package": "electron-builder --dir",
    "package:win": "electron-builder --win",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux",
    "dev:web": "npm run build && node out/server/index.js",
    "build:web": "electron-vite build && tsc -p tsconfig.server.json && node -e \"require('fs').cpSync('src/server/web-bridge.js','out/server/web-bridge.js')\"",
    "start:web": "node out/server/index.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.28.0",
    "socket.io": "^4.7.4",
    "ssh2": "^1.15.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/ssh2": "^1.15.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.5.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "electron-vite": "^5.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "build": {
    "appId": "com.opsclaw.app",
    "productName": "Ops Claw",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}